<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark input background so white text is visible in dark mode -->
    <solid android:color="@color/accent_dark" />
    <corners android:radius="12dp" />
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />
    <stroke
        android:width="1dp"
        android:color="@color/accent_light" />
</shape>
