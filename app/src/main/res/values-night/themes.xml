<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base dark theme variant using the requested palette. -->
    <style name="Base.Theme.ToDoApp" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/blue_primary_light</item>
        <item name="colorPrimaryVariant">@color/blue_primary</item>
        <item name="colorSecondary">@color/blue_primary_light</item>

        <!-- Dark surfaces & text -->
        <item name="android:colorBackground">@color/accent_dark</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/accent_light</item>
    </style>

    <!-- Override primary button text color in dark mode so it contrasts on light buttons -->
    <style name="Widget.ToDoApp.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">@color/accent_dark</item>
    </style>
</resources>